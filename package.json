{
  "name": "carvis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run typecheck && npm run setup:smoke && npm run setup:spawn-smoke && npm run setup:systemd-smoke && npm run setup:systemd-install-smoke && npm run messagebus:smoke && npm run electron:smoke && npm run electron:ui-smoke && npm run electron:browser-smoke && npm run agentruntime:smoke && npm run pidagent:smoke && npm run runtime-pidagent:smoke && npm run workplaces:smoke && npm run output:smoke && npm run claudecode:smoke && npm run e2e:smoke && npm run ipc:smoke && npm run ipc:reconnect-smoke",
    "start": "node dist/main.js",
    "setup:smoke": "npm run build && node dist/setup/smoke.js",
    "setup:spawn-smoke": "npm run build && node dist/setup/spawnSmoke.js",
    "setup:systemd-smoke": "npm run build && node dist/setup/systemdSmoke.js",
    "setup:systemd-install": "npm run build && node dist/setup/systemdInstall.js",
    "setup:systemd-install-smoke": "npm run build && node dist/setup/systemdInstallSmoke.js",
    "messagebus:start": "node dist/messagebus/main.js",
    "agentruntime:start": "node dist/agentruntime/main.js",
    "electron:start": "node dist/electron/main.js",
    "electron:browser-start": "npm run build && node dist/electron/runBrowserMain.js",
    "messagebus:smoke": "npm run build && node dist/messagebus/smoke.js",
    "electron:smoke": "npm run build && node dist/electron/smoke.js",
    "electron:ui-smoke": "npm run build && node dist/electron/uiSmoke.js",
    "electron:browser-smoke": "npm run build && node dist/electron/browserSmoke.js",
    "electron:visual-smoke": "npm run build && node dist/electron/runBrowserVisualSmoke.js",
    "agentruntime:smoke": "npm run build && node dist/agentruntime/smoke.js",
    "pidagent:smoke": "npm run build && node dist/agentruntime/pidagent/smoke.js",
    "runtime-pidagent:smoke": "npm run build && node dist/smoke/runtimePidAgent.js",
    "claudecode:smoke": "npm run build && node dist/agentruntime/claudecode/smoke.js",
    "claudecode:sdk-smoke": "npm run build && node dist/agentruntime/claudecode/warmSdkSmoke.js",
    "provider:smoke": "npm run build && node dist/agentruntime/provider/smoke.js",
    "artist-image-mcp:smoke": "npm run build && node dist/agentruntime/mcp/smoke.js",
    "workplaces:smoke": "npm run build && node dist/agentruntime/workplaces/smoke.js",
    "output:smoke": "npm run build && node dist/output/smoke.js",
    "e2e:smoke": "npm run build && node dist/smoke/e2e.js",
    "ipc:smoke": "npm run build && node dist/smoke/ipc.js",
    "ipc:reconnect-smoke": "npm run build && node dist/smoke/ipcReconnect.js",
    "mvp:real-smoke": "npm run build && node dist/smoke/realMvp.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197"
  }
}
