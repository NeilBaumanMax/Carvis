{
  "name": "carvis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run start:full",
    "start:plan": "node dist/main.js",
    "start:full": "npm run build && CARVIS_SETUP_MODE=spawn CARVIS_SETUP_HOLD_OPEN=1 node dist/main.js",
    "start:full:smoke": "npm run build && node dist/setup/fullSmoke.js",
    "setup:smoke": "npm run build && node dist/setup/smoke.js",
    "messagebus:smoke": "npm run build && node dist/messagebus/smoke.js",
    "agentruntime:smoke": "npm run build && node dist/agentruntime/smoke.js",
    "full:smoke": "npm run build && node dist/agentruntime/fullSmoke.js",
    "claudecode:smoke": "npm run build && node dist/agentruntime/claudecode/smoke.js",
    "workplaces:smoke": "npm run build && node dist/agentruntime/workplaces/smoke.js",
    "electron:start": "electron src/electron/windowMain.cjs",
    "electron:mock": "node dist/electron/main.js",
    "electron:smoke": "npm run build && node dist/electron/smoke.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "electron": "^43.0.0",
    "typescript": "^5.8.3"
  }
}
