{
  "name": "carvis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "setup:smoke": "npm run build && node dist/setup/smoke.js",
    "messagebus:smoke": "npm run build && node dist/messagebus/smoke.js",
    "electron:smoke": "npm run build && node dist/electron/smoke.js",
    "agentruntime:smoke": "npm run build && node dist/agentruntime/smoke.js",
    "claudecode:smoke": "npm run build && node dist/agentruntime/claudecode/smoke.js",
    "workplaces:smoke": "npm run build && node dist/agentruntime/workplaces/smoke.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  }
}
